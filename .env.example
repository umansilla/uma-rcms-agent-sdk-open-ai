# ─── OpenAI ───────────────────────────────────────────────────────
# Required: your OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-...

# Optional: Realtime model to use (default shown below)
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# ─── Server ───────────────────────────────────────────────────────
# Port the server listens on (default: 8000)
PORT=8000

# TLS certificate paths — required for Avaya WSS connections
# Leave empty to run plain WS (use a reverse proxy for TLS instead)
SSL_CERT=certs/server.crt
SSL_KEY=certs/server.key

# ─── Avaya JWT authentication (optional) ──────────────────────────
# Set ENABLE_AUTH=true to validate Avaya's JWT Bearer token
ENABLE_AUTH=false

# Secret key for HS256 JWT verification (required when ENABLE_AUTH=true)
# Must match the key configured in Avaya Infinity
JWT_SECRET_KEY=your-secret-here
